# =============================================================================
# LLM providers for the natural-language query engine (/query Text-to-SQL).
# =============================================================================
#
# PROVIDER PRIORITY + AUTOMATIC FAILOVER (see llm_provider.py):
#   1. Gemini  (primary)  — used first if GEMINI_API_KEY is set.
#   2. OpenAI  (fallback) — used automatically if Gemini fails.
#   3. Groq    (fallback) — used if both Gemini and OpenAI fail (1k RPD free).
#   4. graceful error     — only if ALL providers fail / none configured.
# llm_provider.complete() walks this chain and, on a provider error — most
# importantly a Gemini HTTP 429 / RESOURCE_EXHAUSTED daily-quota error — it
# CASCADES to the next provider instead of surfacing the 429 as the answer.
# So once Gemini's free-tier daily cap is hit, /query keeps answering via OpenAI.
# Anthropic is intentionally dormant/unused (user opted out).
#
# KEY WIRING NOTE: llm_provider.py loads THIS directory's .env with override=True
# so the project key always wins over any stale machine/user-scope env var
# (a pre-existing OPENAI_API_KEY in the OS environment will otherwise shadow the
# project key and break the fallback with a 401). If you deploy by injecting real
# env vars and also ship a .env, the .env values take precedence — don't ship .env
# in that case.

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- OpenAI model (fallback) -------------------------------------------------
# Cheapest DURABLE model for Text-to-SQL. Default: gpt-4.1-nano
#   gpt-4.1-nano : $0.10 /1M input, $0.40 /1M output (mid-2026) — GA, 1M context,
#                  built for classification/extraction (Text-to-SQL fits).
#                  Verified live: returns valid SQL at temperature=0.0.
#   NOT gpt-5-nano: cheaper input ($0.05/1M) BUT it is a reasoning model that
#                  REJECTS non-default temperature on chat.completions
#                  ("temperature does not support 0.0 ... only default (1)"),
#                  so it breaks this pipeline's temperature=0.0/0.2 calls.
#   gpt-4o-mini  : older default, pricier ($0.15/1M in, $0.60/1M out).
# Pricing source: https://openai.com/api/pricing/
OPENAI_MODEL=gpt-4.1-nano

# --- Groq model (second fallback) --------------------------------------------
# Free 1,000 RPD on llama-3.3-70b-versatile. Uses the OpenAI SDK format with
# base_url="https://api.groq.com/openai/v1". Third in the failover chain:
# Gemini -> OpenAI -> Groq. Get a key at https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gemini model (primary) --------------------------------------------------
# Pinned to "gemini-2.5-flash". Avoid the "*-latest" aliases: they resolve to a
# heavier thinking model that spends many internal reasoning tokens even on tiny
# prompts. 2.5-flash roughly halves per-call token burn.
#
# FREE-TIER RATE LIMITS (per MODEL, per PROJECT — extra keys do NOT add quota;
# RPD resets at midnight Pacific). Published values, mid-2026
# (source: https://ai.google.dev/gemini-api/docs/rate-limits):
#   gemini-2.5-flash       ~10-15 RPM | ~1,500 RPD | up to 1M TPM
#   gemini-2.5-flash-lite  ~15-30 RPM | ~1,000-1,500 RPD | 250K-1M TPM (cheaper/faster)
#   gemini-3-flash         ~10 RPM    | ~1,500 RPD | ~250K TPM (newer "recommended")
#   gemini-3.1-flash-lite  ~15 RPM    | ~1,000-1,500 RPD | ~250K TPM
#   gemini-2.0-flash / 2.0-flash-lite : DEPRECATED — shut down 2026-06-01. Do NOT use.
#
# THIS PROJECT'S KEY hits an anomalous ~20 RPD on 2.5-flash
# (GenerateRequestsPerDayPerProjectPerModel-FreeTier, limit 20) — far below the
# published ~1,500, i.e. a restricted/unverified project, not a token problem.
#
# RECOMMENDED one-line change (NOT the default): GEMINI_MODEL=gemini-2.5-flash-lite
#   - equal/higher published RPD + higher RPM, cheaper, adequate for Text-to-SQL;
#   - draws from a SEPARATE per-model daily bucket, so it is not already burned
#     like 2.5-flash. The durable fix for the ~20/day cap is a billing-enabled
#     key; until then the OpenAI fallback above is what guarantees uptime.
GEMINI_MODEL=gemini-2.5-flash

# Optional knobs (defaults shown): request timeout (s) and transient HTTP retries.
# LLM_TIMEOUT_SECONDS=45
# LLM_HTTP_RETRIES=2

USE_GPU=false
